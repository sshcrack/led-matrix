#!/bin/sh
set -e
. /usr/share/debconf/confmodule

# Ask hardware configuration questions
db_input high led-matrix/led-rows || true
db_input high led-matrix/led-cols || true
db_input high led-matrix/led-chain || true
db_input high led-matrix/led-parallel || true
db_input high led-matrix/led-slowdown-gpio || true
db_input medium led-matrix/extra-opts || true
db_go || true

# Ask Spotify question, then conditionally ask for credentials
db_input medium led-matrix/spotify-enable || true
db_go || true

db_get led-matrix/spotify-enable
if [ "$RET" = "true" ]; then
    db_input high led-matrix/spotify-client-id || true
    db_input high led-matrix/spotify-client-secret || true
    db_go || true
fi

# Ask update configuration questions
db_input medium led-matrix/auto-update-enable || true
db_go || true

db_get led-matrix/auto-update-enable
if [ "$RET" = "true" ]; then
    db_input medium led-matrix/auto-update-interval || true
    db_go || true
fi

exit 0
