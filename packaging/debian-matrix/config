#!/bin/sh
set -e
. /usr/share/debconf/confmodule

# Ask hardware configuration questions (only if not already set)
db_get led-matrix/led-rows
if [ -z "$RET" ]; then db_input high led-matrix/led-rows || true; fi
db_get led-matrix/led-cols
if [ -z "$RET" ]; then db_input high led-matrix/led-cols || true; fi
db_get led-matrix/led-chain
if [ -z "$RET" ]; then db_input high led-matrix/led-chain || true; fi
db_get led-matrix/led-parallel
if [ -z "$RET" ]; then db_input high led-matrix/led-parallel || true; fi
db_get led-matrix/led-slowdown-gpio
if [ -z "$RET" ]; then db_input high led-matrix/led-slowdown-gpio || true; fi
db_get led-matrix/extra-opts
if [ -z "$RET" ]; then db_input medium led-matrix/extra-opts || true; fi
db_go || true

# Ask Spotify question, then conditionally ask for credentials
db_get led-matrix/spotify-enable
if [ -z "$RET" ]; then
    db_input medium led-matrix/spotify-enable || true
    db_go || true
fi

db_get led-matrix/spotify-enable
if [ "$RET" = "true" ]; then
    db_get led-matrix/spotify-client-id
    if [ -z "$RET" ]; then db_input high led-matrix/spotify-client-id || true; fi
    db_get led-matrix/spotify-client-secret
    if [ -z "$RET" ]; then db_input high led-matrix/spotify-client-secret || true; fi
    db_go || true
fi

# Ask update configuration questions
db_get led-matrix/auto-update-enable
if [ -z "$RET" ]; then
    db_input medium led-matrix/auto-update-enable || true
    db_go || true
fi

db_get led-matrix/auto-update-enable
if [ "$RET" = "true" ]; then
    db_get led-matrix/auto-update-interval
    if [ -z "$RET" ]; then db_input medium led-matrix/auto-update-interval || true; fi
    db_go || true
fi

exit 0
